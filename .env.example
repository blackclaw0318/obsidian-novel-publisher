# ============================================================
# obsidian-novel-publisher 环境变量模板
# ============================================================
# 复制为 .env 并填入真实值, .env 已被 gitignore
# 凭据安全协议: 真实值不入 git, 不入日志, 不入 prompt
# ============================================================

# LLM (minimax M3 — 写作)
MINIMAXI_API_KEY=sk-cp-...
MINIMAXI_BASE_URL=https://api.minimaxi.com/v1
MINIMAXI_TEXT_MODEL=MiniMax-M3

# 图像 (minimax image-01 — 封面图, v0.2 新增)
MINIMAXI_IMAGE_MODEL=image-01

# obsidian-journal 接收侧 (HMAC 鉴权)
OBSIDIAN_PUBLISH_URL=https://shangkun.uk/api/external/posts
OBSIDIAN_PUBLISH_ID=novel-publisher
OBSIDIAN_PUBLISH_SECRET=change-me-32-bytes-random-hex

# 告警 (复用 xhs-novel-bot WeCom webhook)
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=...

# 调度
PUBLISH_TIMES=08:00,12:00,18:00
TIMEZONE=Asia/Shanghai

# 日志
LOG_LEVEL=INFO
LOG_DIR=./logs