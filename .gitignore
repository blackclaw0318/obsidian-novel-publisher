# ============================================================
# obsidian-novel-publisher .gitignore
# ============================================================

# 凭据 (凭据安全协议)
.env
.env.local
.env.*.local

# 状态 / 日志 / 临时数据
data/state.json
data/*.local.json
logs/
*.log
__pycache__/
*.pyc
*.pyo
*.pyd

# 测试 / 覆盖率
coverage/
.coverage
.nyc_output/

# 编辑器 / 系统
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# 调度
data/novel/*/drafts/
output/