# ============================================================
# obsidian-novel-publisher .gitignore
# ============================================================

# 凭据 (凭据安全协议)
.env
.env.local
.env.*.local

# 状态 / 日志 / 临时数据
data/state.json
data/*.local.json
logs/
*.log
__pycache__/
*.pyc
*.pyo
*.pyd

# Python venv (本地开发用, 绝不进仓)
.venv/
venv/
env/

# 测试 / 覆盖率
coverage/
.coverage
.nyc_output/

# 编辑器 / 系统
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# 调度
data/novel/*/drafts/
output/
# 凭据备份 (本地恢复用, 绝不进仓)
.env.bak.*
.env.bak

# 数据目录 (gitignored, 备份走 obsidian-novel-backups 仓)
data/
data/covers/
data/state.json.lock
data/cache/
